# BarFlow — Variables d'environnement serveur
# Copier ce fichier en .env à la racine du dossier server/

# ── Base de données ───────────────────────────────────────────
DATABASE_URL="postgresql://postgres.oelhvgdqjrwrzyiunbeo:Noah17132anna%20Senegal@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"
PORT=3001

# ── Wave Business API ─────────────────────────────────────────
# Récupérer sur https://business.wave.com → Developers → API Keys
# Format production : secret_live_xxxxxxxxxxxxxxxxxxxx
# Format sandbox   : secret_test_xxxxxxxxxxxxxxxxxxxx
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# ── Orange Money (Sonatel) API ────────────────────────────────
# Récupérer sur https://developer.orange-sonatel.com
# Créer une app → récupérer Client ID et Client Secret
OM_CLIENT_ID=
OM_CLIENT_SECRET=
# Code marchand Orange Money (fourni par Sonatel après validation)
OM_MERCHANT_CODE=
# URLs API (ne pas modifier sauf si Orange change ses endpoints)
OM_TOKEN_URL=https://api.orange-sonatel.com/oauth/v3/token
OM_API_URL=https://api.orange-sonatel.com

# ── Email (Gmail SMTP via Nodemailer) — GRATUIT ───────────────
# Utilisé pour l'envoi du code de récupération de mot de passe.
# 1. Active la validation en 2 étapes sur ton compte Gmail :
#    https://myaccount.google.com/security
# 2. Génère un "mot de passe d'application" (App Password) ici :
#    https://myaccount.google.com/apppasswords
#    → Choisis "Autre" comme application, nomme-le "BarFlow"
# 3. Colle l'adresse Gmail et le mot de passe généré (16 caractères,
#    sans espaces) ci-dessous. NE PAS utiliser ton mot de passe Gmail normal.
GMAIL_USER=
GMAIL_APP_PASSWORD=